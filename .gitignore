*.tar.gz

# Database local
*.db
*.sqlite
*.sqlite3

# Docker volumes (NUNCA versionar)
volumes/

# Environment files
.env
*.env

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Git
.git/
install.sh.bak
