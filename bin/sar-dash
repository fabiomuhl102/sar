#!/bin/bash

# =====================================================
# SAR - DASHBOARD CENTRAL
# =====================================================

source /opt/automacao/scripts/lib/configuracao.sh
source /opt/automacao/scripts/lib/identidade.sh
source /opt/automacao/scripts/lib/docker.sh

clear

echo "=========================================================="
echo "           SAR - PAINEL DE CONTROLE"
echo "=========================================================="
echo

# -----------------------------------------------------
# SISTEMA
# -----------------------------------------------------
echo "🖥 SISTEMA"
echo "----------------------------------------------------------"
echo "Hostname...........: $(hostname)"
echo "Uptime.............: $(uptime -p)"
echo "Kernel.............: $(uname -r)"
echo

# -----------------------------------------------------
# CPU / MEMÓRIA
# -----------------------------------------------------
echo "💾 RECURSOS"
echo "----------------------------------------------------------"
echo "Memória............: $(free -h | awk '/Mem:/ {print $3 " / " $2}')"
echo "Load Average.......: $(uptime | awk -F'load average:' '{print $2}')"
echo

# -----------------------------------------------------
# DISCO
# -----------------------------------------------------
echo "💽 ARMAZENAMENTO"
echo "----------------------------------------------------------"
df -h / | awk 'NR==2 {print "Sistema...........: " $3 " / " $2 " (" $5 ")"}'
df -h /mnt/backups | awk 'NR==2 {print "Backup............: " $3 " / " $2 " (" $5 ")"}'
echo

# -----------------------------------------------------
# DOCKER
# -----------------------------------------------------
echo "🐳 DOCKER"
echo "----------------------------------------------------------"
if command -v docker >/dev/null 2>&1; then
    echo "Status............: ATIVO"
    echo "Containers........: $(docker ps -q | wc -l)"
else
    echo "Status............: INATIVO"
fi
echo

# -----------------------------------------------------
# SAR SERVICES
# -----------------------------------------------------
echo "⚙ SAR"
echo "----------------------------------------------------------"
echo "Diretório.........: /opt/automacao"
echo "Backup............: /mnt/backups"
echo "Último backup.....: $(ls -t /mnt/backups/sar_backup_*.tar.gz 2>/dev/null | head -1)"
echo

# -----------------------------------------------------
# LOG RESUMIDO
# -----------------------------------------------------
echo "📊 LOG (últimas 5 linhas)"
echo "----------------------------------------------------------"
tail -n 5 /opt/automacao/logs/sar.log 2>/dev/null
echo

echo "=========================================================="
echo "                FIM DO PAINEL SAR"
echo "=========================================================="
