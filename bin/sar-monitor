#!/bin/bash

# =====================================================
# SAR - Servidor de Automação Residencial
# Comando: sar-monitor
# Versão: 0.1.0
# =====================================================

source /opt/automacao/scripts/lib/configuracao.sh
source "$SAR_LIB/identidade.sh"
source "$SAR_LIB/ui.sh"

# -----------------------------------------------------
# Cabeçalho
# -----------------------------------------------------
ui_titulo "MONITORAMENTO DO SISTEMA"

# -----------------------------------------------------
# Uptime
# -----------------------------------------------------
UPTIME=$(uptime -p)

# -----------------------------------------------------
# CPU load
# -----------------------------------------------------
LOAD=$(cat /proc/loadavg | awk '{print $1" "$2" "$3}')

# -----------------------------------------------------
# Memória
# -----------------------------------------------------
MEM_TOTAL=$(free -h | awk '/Mem/ {print $2; exit}')
MEM_USED=$(free -h | awk '/Mem/ {print $3; exit}')

# -----------------------------------------------------
# Disco sistema
# -----------------------------------------------------
DISCO=$(df -h / | awk 'NR==2 {print $3" / "$2" ("$5")"}')

# -----------------------------------------------------
# Disco backup
# -----------------------------------------------------
BACKUP=$(df -h /mnt/backups | awk 'NR==2 {print $3" / "$2" ("$5")"}')

# -----------------------------------------------------
# Saída
# -----------------------------------------------------
echo "Uptime.............: $UPTIME"
echo "Load Average.......: $LOAD"
echo
echo "Memória............: $MEM_USED / $MEM_TOTAL"
echo
echo "Disco Sistema......: $DISCO"
echo "Disco Backup.......: $BACKUP"
echo
