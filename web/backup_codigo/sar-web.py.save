                background:#000;
                padding:10px;
                overflow:auto;
            }}
            .metric {{
                font-size:18px;
                margin:5px 0;
            }}
        </style>
    </head>
    <body>

    <h1>🚀 SAR Dashboard</h1>

    <div class="box">
        <h2>Sistema</h2>
        <div class="metric">Uptime: {uptime}</div>
        <div class="metric">Load: {load}</div>
    </div>

    <div class="box">
        <h2>📊 Recursos</h2>
        <div class="metric">CPU: {cpu}%</div>
        <div class="metric">Memória: {mem_pct}% ({mem_text})</div>
    </div>

    <div class="box">
        <h2>💾 Disco</h2>
        <div class="metric">{disk}</div>
    </div>

    <div class="box">
        <h2>🐳 Docker</h2>
        <div class="metric">Containers ativos: {docker}</div>
    </div>

    <div class="box">
        <h2>📜 Logs</h2>
        <pre>{logs}</pre>
    </div>

    </body>
    </html>
    """

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=8088)
